# ── AI Providers ──────────────────────────────────────────────────────────────

# Yandex Cloud (Orchestrator + product_lead + logic_lead)
YANDEX_API_KEY=your_yandex_api_key
YANDEX_FOLDER_ID=your_folder_id

# Perplexity (research_lead)
PERPLEXITY_API_KEY=your_perplexity_key

# Google Gemini (visual_lead + tech_lead)
GEMINI_API_KEY=your_gemini_key

# OpenAI (optional fallback)
# OPENAI_API_KEY=sk-...

# ── Integrations ───────────────────────────────────────────────────────────────

# Figma (figma_reader tool)
FIGMA_ACCESS_TOKEN=your_figma_pat
FIGMA_FILE_KEY=your_figma_file_key

# GitHub (vault_writer tool → coreds-vault)
GITHUB_TOKEN=your_github_pat
GITHUB_REPO=owner/repo-name
GITHUB_BRANCH=master

# ── Component Docs API Keys ────────────────────────────────────────────────────

# Admin token for /keys/generate and /keys/stats endpoints
# Generate: openssl rand -hex 32
ADMIN_TOKEN=your_secret_admin_token

# ── Redis ─────────────────────────────────────────────────────────────────────

# In Docker Compose: "redis" (service name, set automatically by docker-compose.yml)
# Local / bare-metal: "localhost"
# REDIS_HOST=redis

# ── Local LLM (optional) ──────────────────────────────────────────────────────
# LM_STUDIO_URL=http://localhost:1234/v1
